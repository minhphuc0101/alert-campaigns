# === REQUIRED CREDENTIALS ===

# 1. Google Gemini API Key
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# 2. Email Settings (The email ADDRESS sending the alert)
# If using Gmail, you need an App Password: 
# https://support.google.com/accounts/answer/185833
EMAIL_SENDER_ADDRESS="your_sender_email@gmail.com"
EMAIL_SENDER_PASSWORD="your_app_password_here"

# 3. Target Email (Where alerts are sent - Already set)
EMAIL_RECIPIENT_ADDRESS="phuc.tran@digimind.asia"

# 4. Google Sheet Details
# Google Sheets Spreadsheet ID (The string of letters/numbers in the URL)
# e.g., for https://docs.google.com/spreadsheets/d/1BxiMVs0X85n8_z_dwX/edit
# The ID is: 1BxiMVs0X85n8_z_dwX
GOOGLE_SHEET_ID="your_google_sheet_id_here"
# The exact name of the tab in your spreadsheet (e.g., "Sheet1")
GOOGLE_SHEET_TAB_NAME="Sheet1"
